<!DOCTYPE html>
<html lang="it">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>LagoBeat | Relax sul Lago</title>

<meta name="description" content="Casa vacanza LagoBeat. Relax sul lago, natura, sport e attività. Verifica disponibilità e prenota ora.">

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

<style>

body{
font-family:Arial;
margin:0;
background:#f9fbff;
color:#333;
}

header{
height:70vh;
background:url("https://images.unsplash.com/photo-1507525428034-b723cf961d3e") center/cover;
display:flex;
align-items:center;
justify-content:center;
color:white;
text-align:center;
}

header h1{
font-size:48px;
background:rgba(0,0,0,0.4);
padding:20px;
border-radius:10px;
}

section{
padding:70px 20px;
max-width:1100px;
margin:auto;
}

h2{
text-align:center;
margin-bottom:40px;
}

/* attività */

.attivita{
background:linear-gradient(135deg,#eaf6ff,#d6ecff,#c1e3ff);
border-radius:20px;
padding:40px;
}

/* booking */

.booking{
background:white;
padding:40px;
border-radius:15px;
box-shadow:0 10px 30px rgba(0,0,0,0.1);
}

.booking input,
.booking select{
width:100%;
padding:12px;
margin:10px 0;
border-radius:8px;
border:1px solid #ddd;
}

.booking button{
background:#1da1f2;
color:white;
padding:14px;
border:none;
border-radius:8px;
font-size:16px;
cursor:pointer;
width:100%;
}

.price{
font-size:22px;
font-weight:bold;
text-align:center;
margin-top:10px;
}

/* whatsapp */

.whatsapp{
position:fixed;
bottom:20px;
right:20px;
background:#25D366;
color:white;
font-size:28px;
width:60px;
height:60px;
border-radius:50%;
display:flex;
align-items:center;
justify-content:center;
text-decoration:none;
box-shadow:0 5px 20px rgba(0,0,0,0.2);
}

/* gallery */

.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
}

.gallery img{
width:100%;
border-radius:10px;
}

footer{
background:#0a2540;
color:white;
text-align:center;
padding:30px;
}

</style>

</head>

<body>

<header>
<h1>LagoBeat Relax sul Lago</h1>
</header>

<section>

<h2>La Struttura</h2>

<div class="gallery">

<img src="https://images.unsplash.com/photo-1501785888041-af3ef285b470">
<img src="https://images.unsplash.com/photo-1500530855697-b586d89ba3ee">
<img src="https://images.unsplash.com/photo-1506744038136-46273834b3fb">

</div>

</section>

<section class="attivita">

<h2>Attività</h2>

<p style="text-align:center">

Kayak • Trekking • Mountain Bike • Relax sul lago • Escursioni

</p>

</section>

<section>

<h2>Verifica disponibilità</h2>

<div class="booking">

<input id="arrivo" placeholder="Data arrivo">

<input id="partenza" placeholder="Data partenza">

<select id="ospiti">

<option>Ospiti</option>
<option>1</option>
<option>2</option>
<option>3</option>
<option>4</option>

</select>

<div class="price" id="prezzo">
Prezzo totale: —
</div>

<button onclick="prenota()">
Richiedi disponibilità
</button>

</div>

</section>

<section>

<h2>Dove siamo</h2>

<iframe
src="https://maps.google.com/maps?q=lago%20di%20como&t=&z=11&ie=UTF8&iwloc=&output=embed"
width="100%"
height="400"
style="border:0;border-radius:10px">
</iframe>

</section>

<footer>

© LagoBeat 2026

</footer>

<a class="whatsapp" href="https://wa.me/393000000000">💬</a>

<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<script>

flatpickr("#arrivo",{dateFormat:"Y-m-d"});
flatpickr("#partenza",{dateFormat:"Y-m-d"});

const prezzoNotte = 120;

document.querySelectorAll("#arrivo,#partenza")
.forEach(el => el.addEventListener("change",calcola));

function calcola(){

let a = new Date(document.getElementById("arrivo").value);
let p = new Date(document.getElementById("partenza").value);

if(a && p){

let giorni = (p-a)/(1000*60*60*24);

if(giorni>0){

let prezzo = giorni * prezzoNotte;

document.getElementById("prezzo")
.innerHTML = "Prezzo totale: €"+prezzo;

}

}

}

function prenota(){

let arrivo = document.getElementById("arrivo").value;
let partenza = document.getElementById("partenza").value;
let ospiti = document.getElementById("ospiti").value;

let messaggio =
`Richiesta disponibilità LagoBeat

Arrivo: ${arrivo}
Partenza: ${partenza}
Ospiti: ${ospiti}`;

let url = "https://wa.me/393000000000?text="+encodeURIComponent(messaggio);

window.open(url,"_blank");

}

</script>

</body>

</html>
