<!DOCTYPE html>
<html lang="it">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>LagoBeat | Relax sul Lago</title>

<meta name="description" content="LagoBeat casa vacanze sul lago. Relax, natura, escursioni e attività. Verifica disponibilità e contattaci.">

<style>

body{
margin:0;
font-family:Arial, Helvetica, sans-serif;
background:#f7f9fc;
color:#333;
}

/* HERO */

.hero{
height:85vh;
background:url("hero.jpg") center/cover no-repeat;
display:flex;
align-items:center;
justify-content:center;
text-align:center;
color:white;
}

.hero h1{
font-size:48px;
background:rgba(0,0,0,0.45);
padding:25px 40px;
border-radius:10px;
}

/* SEZIONI */

section{
padding:70px 20px;
max-width:1100px;
margin:auto;
}

h2{
text-align:center;
margin-bottom:40px;
}

/* ATTIVITA */

.attivita{
background:linear-gradient(135deg,#e9f6ff,#cfeaff,#b7e0ff);
padding:50px;
border-radius:15px;
text-align:center;
font-size:18px;
}

/* GALLERY */

.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
}

.gallery img{
width:100%;
border-radius:10px;
}

/* BOOKING */

.booking{
background:white;
padding:35px;
border-radius:12px;
box-shadow:0 10px 25px rgba(0,0,0,0.1);
max-width:500px;
margin:auto;
}

.booking input,
.booking select{
width:100%;
padding:12px;
margin-bottom:12px;
border-radius:6px;
border:1px solid #ccc;
}

.booking button{
width:100%;
padding:14px;
background:#1da1f2;
color:white;
border:none;
border-radius:8px;
font-size:16px;
cursor:pointer;
}

.price{
text-align:center;
font-weight:bold;
font-size:20px;
margin-bottom:10px;
}

/* MAP */

.map iframe{
border-radius:10px;
}

/* WHATSAPP */

.whatsapp{
position:fixed;
bottom:20px;
right:20px;
width:60px;
height:60px;
background:#25D366;
border-radius:50%;
display:flex;
align-items:center;
justify-content:center;
font-size:30px;
color:white;
text-decoration:none;
box-shadow:0 5px 15px rgba(0,0,0,0.3);
}

/* FOOTER */

footer{
background:#0a2540;
color:white;
text-align:center;
padding:30px;
}

</style>

</head>

<body>

<!-- HERO -->

<div class="hero">
<h1>LagoBeat Relax sul Lago</h1>
</div>

<!-- GALLERY -->

<section>

<h2>La Struttura</h2>

<div class="gallery">

<img src="foto1.jpg">
<img src="foto2.jpg">
<img src="foto3.jpg">

</div>

</section>

<!-- ATTIVITA -->

<section class="attivita">

<h2>Attività</h2>

<p>
Kayak • Trekking • Mountain Bike • Escursioni • Relax sul Lago
</p>

</section>

<!-- PRENOTAZIONE -->

<section>

<h2>Verifica disponibilità</h2>

<div class="booking">

<input type="date" id="arrivo">

<input type="date" id="partenza">

<select id="ospiti">
<option>Numero ospiti</option>
<option>1</option>
<option>2</option>
<option>3</option>
<option>4</option>
</select>

<div class="price" id="prezzo">
Prezzo stimato: —
</div>

<button onclick="prenota()">
Richiedi disponibilità
</button>

</div>

</section>

<!-- MAPPA -->

<section class="map">

<h2>Dove siamo</h2>

<iframe
src="https://maps.google.com/maps?q=lago&t=&z=12&ie=UTF8&iwloc=&output=embed"
width="100%"
height="400"
frameborder="0">
</iframe>

</section>

<footer>

<p>© LagoBeat Casa Vacanze</p>

</footer>

<a class="whatsapp" href="https://wa.me/393000000000">💬</a>

<script>

const prezzoNotte = 120;

document.querySelectorAll("#arrivo,#partenza")
.forEach(el => el.addEventListener("change",calcola));

function calcola(){

let arrivo = new Date(document.getElementById("arrivo").value);
let partenza = new Date(document.getElementById("partenza").value);

if(arrivo && partenza){

let giorni = (partenza-arrivo)/(1000*60*60*24);

if(giorni>0){

let prezzo = giorni * prezzoNotte;

document.getElementById("prezzo")
.innerHTML = "Prezzo stimato: €"+prezzo;

}

}

}

function prenota(){

let arrivo = document.getElementById("arrivo").value;
let partenza = document.getElementById("partenza").value;
let ospiti = document.getElementById("ospiti").value;

let messaggio =
`Richiesta disponibilità LagoBeat

Arrivo: ${arrivo}
Partenza: ${partenza}
Ospiti: ${ospiti}`;

let url = "https://wa.me/393000000000?text="+encodeURIComponent(messaggio);

window.open(url,"_blank");

}

</script>

</body>

</html>
